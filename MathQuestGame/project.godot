[physics]

common/physics_ticks_per_second=120
3d/default_gravity=9.8

[debug]

settings/force_fps=0
settings/collision_shape_color_debug_visibility=false

[editor_plugins]

enabled=PackedStringArray()

[platform.android]

permissions=PackedStringArray("android.permission.VIBRATE")
